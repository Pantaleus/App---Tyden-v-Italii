{
  "expo": {
    "name": "App---Tyden-v-Italii",
    "slug": "App---Tyden-v-Italii",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pantaleus.tyden_v_italii"
    },
    "android": {
      "package": "com.pantaleus.tyden_v_italii",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Aplikace potřebuje přístup k fotoaparátu pro skenování přihlašovacího QR kódu."
        }
      ]
    ]
  }
}
